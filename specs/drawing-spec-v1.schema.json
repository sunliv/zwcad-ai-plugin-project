{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/zwcad-ai/drawing-spec-v1.schema.json",
  "title": "DrawingSpec v1",
  "description": "DrawingSpec v1 public wire contract. All 2D points use array form [x, y]; object-shaped points are invalid on the wire.",
  "type": "object",
  "additionalProperties": false,
  "required": ["drawingSpecVersion", "units", "layers", "entities"],
  "properties": {
    "drawingSpecVersion": {
      "type": "string",
      "const": "1.0"
    },
    "units": {
      "type": "string",
      "enum": ["mm", "cm", "m", "inch"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "domain": { "type": "string" },
        "author": { "type": "string" },
        "createdBy": { "type": "string" },
        "requestId": { "type": "string" }
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/layer" }
    },
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity" }
    },
    "dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension" }
    },
    "clarifications": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "point2d": {
      "description": "2D model-space point encoded as [x, y]. Coordinates are numeric values in DrawingSpec units.",
      "type": "array",
      "prefixItems": [
        { "type": "number" },
        { "type": "number" }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "color": { "type": "integer", "minimum": 1, "maximum": 255 },
        "lineType": { "type": "string" },
        "lineWeight": { "type": "number" }
      }
    },
    "commonEntity": {
      "type": "object",
      "required": ["id", "type", "layer"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
        "type": { "type": "string" },
        "layer": { "type": "string", "minLength": 1 }
      }
    },
    "entity": {
      "oneOf": [
        { "$ref": "#/$defs/line" },
        { "$ref": "#/$defs/polyline" },
        { "$ref": "#/$defs/circle" },
        { "$ref": "#/$defs/arc" },
        { "$ref": "#/$defs/text" },
        { "$ref": "#/$defs/centerMark" }
      ]
    },
    "line": {
      "allOf": [
        { "$ref": "#/$defs/commonEntity" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "layer", "start", "end"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
            "type": { "const": "line" },
            "layer": { "type": "string" },
            "start": { "$ref": "#/$defs/point2d" },
            "end": { "$ref": "#/$defs/point2d" }
          }
        }
      ]
    },
    "polyline": {
      "allOf": [
        { "$ref": "#/$defs/commonEntity" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "layer", "points"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
            "type": { "const": "polyline" },
            "layer": { "type": "string" },
            "closed": { "type": "boolean" },
            "points": {
              "type": "array",
              "minItems": 2,
              "items": { "$ref": "#/$defs/point2d" }
            }
          }
        }
      ]
    },
    "circle": {
      "allOf": [
        { "$ref": "#/$defs/commonEntity" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "layer", "center", "radius"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
            "type": { "const": "circle" },
            "layer": { "type": "string" },
            "center": { "$ref": "#/$defs/point2d" },
            "radius": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    },
    "arc": {
      "allOf": [
        { "$ref": "#/$defs/commonEntity" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "layer", "center", "radius", "startAngle", "endAngle"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
            "type": { "const": "arc" },
            "layer": { "type": "string" },
            "center": { "$ref": "#/$defs/point2d" },
            "radius": { "type": "number", "exclusiveMinimum": 0 },
            "startAngle": { "type": "number" },
            "endAngle": { "type": "number" }
          }
        }
      ]
    },
    "text": {
      "allOf": [
        { "$ref": "#/$defs/commonEntity" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "layer", "position", "value", "height"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
            "type": { "enum": ["text", "mtext"] },
            "layer": { "type": "string" },
            "position": { "$ref": "#/$defs/point2d" },
            "value": { "type": "string" },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "rotation": { "type": "number" }
          }
        }
      ]
    },
    "centerMark": {
      "allOf": [
        { "$ref": "#/$defs/commonEntity" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "layer", "center", "size"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
            "type": { "const": "centerMark" },
            "layer": { "type": "string" },
            "center": { "$ref": "#/$defs/point2d" },
            "size": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    },
    "dimension": {
      "oneOf": [
        { "$ref": "#/$defs/linearDimension" },
        { "$ref": "#/$defs/alignedDimension" },
        { "$ref": "#/$defs/radiusDimension" },
        { "$ref": "#/$defs/diameterDimension" },
        { "$ref": "#/$defs/angularDimension" }
      ]
    },
    "linearDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "layer", "from", "to", "offset"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
        "type": { "const": "linear" },
        "layer": { "type": "string", "minLength": 1 },
        "from": { "$ref": "#/$defs/point2d" },
        "to": { "$ref": "#/$defs/point2d" },
        "offset": { "$ref": "#/$defs/point2d" },
        "text": { "type": "string" }
      }
    },
    "alignedDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "layer", "from", "to", "offset"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
        "type": { "const": "aligned" },
        "layer": { "type": "string", "minLength": 1 },
        "from": { "$ref": "#/$defs/point2d" },
        "to": { "$ref": "#/$defs/point2d" },
        "offset": { "$ref": "#/$defs/point2d" },
        "text": { "type": "string" }
      }
    },
    "radiusDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "layer", "targetEntityId"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
        "type": { "const": "radius" },
        "layer": { "type": "string", "minLength": 1 },
        "targetEntityId": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
        "text": { "type": "string" }
      }
    },
    "diameterDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "layer", "targetEntityId"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
        "type": { "const": "diameter" },
        "layer": { "type": "string", "minLength": 1 },
        "targetEntityId": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
        "text": { "type": "string" }
      }
    },
    "angularDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "layer", "center", "from", "to", "offset"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
        "type": { "const": "angular" },
        "layer": { "type": "string", "minLength": 1 },
        "center": { "$ref": "#/$defs/point2d" },
        "from": { "$ref": "#/$defs/point2d" },
        "to": { "$ref": "#/$defs/point2d" },
        "offset": { "$ref": "#/$defs/point2d" },
        "text": { "type": "string" }
      }
    }
  }
}
